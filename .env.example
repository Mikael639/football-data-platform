# Core database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=football_dw
DB_USER=football
DB_PASSWORD=football

# Local dashboard
DASHBOARD_PORT=9001

# football-data.org
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITION=PD
FOOTBALL_DATA_SEASON=
FOOTBALL_DATA_TEAM_NAME=Real Madrid CF

# Pipeline runtime
PIPELINE_MODE=api

# Study / Supabase
SUPABASE_DB_URL=
STUDY_SUPABASE_DB_URL=
FBREF_STUDY_BACKEND=local
FBREF_STUDY_MIN_MINUTES=600
FBREF_STUDY_SOURCE=soccerdata
FBREF_LEAGUE_CODE=ESP-La Liga
FBREF_NUM_PAST_SEASONS=3
FBREF_STUDY_OUTDIR=data/study/fbref
FBREF_MANUAL_MATCH_CSV=data/study/fbref_input/player_match_manual.csv
FBREF_PROXY=
FBREF_NO_CACHE=false

# FBref cleaned/manual import helpers
FBREF_CLEANED_INPUT_GLOB=data/raw/*_cleaned.csv
FBREF_CLEANED_OUT_CSV=data/study/fbref_input/player_match_manual.csv
FBREF_CLEANED_COMPETITION=La Liga
FBREF_CLEANED_LEAGUE_LABEL=La Liga (FBref manuel)
FBREF_STANDARD_GLOB=data/raw/laliga_*_standard.csv

# Supabase import helpers
SUPABASE_IMPORT_APPLY_SCHEMA=true
SUPABASE_IMPORT_SCHEMA_SQL=sql/05_supabase_fbref_study.sql

# FBref match log import helpers
FBREF_MATCHLOG_SEASON_START=
FBREF_MATCHLOG_SEASONS=
FBREF_MATCHLOG_CSV=data/study/fbref_input/player_match_manual.csv
FBREF_MATCHLOG_LEAGUE_LABEL=La Liga (FBref manuel match logs)
FBREF_MATCHLOG_COMPETITION=La Liga
FBREF_MATCHLOG_REPLACE_GLOBAL=false
