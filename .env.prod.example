# Domain configuration for HTTPS proxy
APP_DOMAIN=football.example.com
TLS_EMAIL=ops@example.com

# Basic Auth (generate hash with: docker run --rm caddy:2.8-alpine caddy hash-password --plaintext "change-me")
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=
DASHBOARD_ADMIN_USERNAME=admin
DASHBOARD_ADMIN_PASSWORD=admin123!

# Database names/users (passwords are loaded from Docker secrets files)
POSTGRES_DB=football_dw
POSTGRES_SUPERUSER=postgres
DB_WRITER_USER=pipeline_rw
DB_READER_USER=dashboard_ro

# Optional token source (recommended: inject from secret manager at deploy time)
FOOTBALL_DATA_TOKEN=
FOOTBALL_DATA_TOKEN_FILE=

# Data mode and ingestion behavior
DATA_MODE=hybrid
PIPELINE_MODE=hybrid
COMPETITION_CODE=PD
LIVE_COMPETITION_CODES=PD,PL,SA,BL1,FL1,CL,EL,UCL
INCREMENTAL=true
INCREMENTAL_DAYS=14
DQ_FRESHNESS_DAYS=7
PIPELINE_INTERVAL_SECONDS=1800
ENRICH_PLAYER_STATS=false
PLAYER_STATS_PROVIDER=fbref
PLAYER_STATS_BASE_URL=
PLAYER_STATS_TOKEN=
PLAYER_STATS_TOKEN_FILE=
PLAYER_STATS_TIMEOUT_SEC=30

# Alerts
ALERTS_ENABLED=true
ALERT_WEBHOOK_URL=
ALERT_SMTP_HOST=
ALERT_SMTP_PORT=587
ALERT_SMTP_USER=
ALERT_SMTP_PASSWORD=
ALERT_SMTP_FROM=
ALERT_SMTP_TO=
ALERT_SMTP_STARTTLS=true

# Optional external DB URLs
DATABASE_URL=
SUPABASE_DB_URL=
SUPABASE_DB_URL_FILE=
STUDY_SUPABASE_DB_URL=
STUDY_SUPABASE_DB_URL_FILE=
